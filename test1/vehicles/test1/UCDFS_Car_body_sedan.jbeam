{
"UCDFS_Car_body_sedan": {
    "variables": [
        ["name", "type", "unit", "category", "default", "min", "max", "title", "description", {"stepDis":100, "subCategory":"Rear"}],
        //["$frontWeight", "range", "Kg", "Chassis", 8, 1, 15, "Front Weight", "Times by 10"],
        //["$rearWeight", "range", "Kg", "Chassis", 5, 1, 8, "Rear Weight", "Times by 30"]
        //["$bodyStiffness", "range", "N/m", "Chassis", 8000000, 2000000, 20000000, "Chassis", ""]	
    ],	
    "information":{
        "authors":"Harry",
        "name":"Sedan Body",
        "value":100,
    },
    "slotType" : "UCDFS_Car_body",
    "flexbodies": [
        ["mesh",                "[group]:", "nonFlexMaterials"],
        ["FS_Chassis",     ["body"],     [], {"pos":{"x": 0,"y":2,"z":-0.05},"scale":{"x":1,"y":1,"z":1}}],
		["body_panels",     ["front"],     [], {"pos":{"x": 0,"y":-0.325,"z":0.425},"rot":{"x":0, "y":0,"z":90}}],//"scale":{"x":1,"y":1,"z":1},
    ],
    //controllers are lua modules used to add higher level control of the vehicle lua (powertrain, electrics, hydros, etc)
    "controller": [
        ["fileName"],
        //vehicleController is required to have a vehicle with functioning powertrain
        ["vehicleController", {}]
    ],
    //refnodes are a reference coordinate system created from nodes of the vehicle. used for camera orientation, spawning location
    //should create an orthogonal shape and the closer to the center of the vehicle the better
    //leftCorner and rightCorner are used for triggering scenario waypoints
    "refNodes":[
        ["ref:", "back:", "left:", "up:"],
        ["frb7r", "frb6r", "frb7l", "frm6r"],
    ],
    //sets the placement of the orbit and chase cameras relative to the "ref:" node
    // python changes the camera position for QoL
    "cameraChase":{
        "distance":5.1,
        "offset":{"x":0, "y":0, "z":0.2},
        "distanceMin":2,
        "defaultRotation":{"x":0,"y":-12,"z":0},
        "fov":65,
    },
    "cameraExternal":{
        "distance":5.1,
        "offset":{"x":0, "y":0, "z":0.2},
        "distanceMin":2,
        "fov":65,
    },

    "nodes": [
        ["id",      "posX",      "posY",    "posZ"],
        {"frictionCoef":0.5},
        {"nodeMaterial":"|NM_METAL"},
        //collision: does the node collide with the ground, static objects, and other vehicle collision tris
        {"collision":true},
        //selfCollision: does the node collide with own collision tris
        {"selfCollision":false},
        //group:used to create a group of nodes that a flexbody (deformable mesh) can be bound to
		
