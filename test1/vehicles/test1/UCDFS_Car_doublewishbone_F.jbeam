{
"UCDFS_Car_doublewishbone_F": {
	
	"information":{
        "authors":"BeamNG",
        "name":"Double Wishbone Front Suspension",
        "value":150,
    },
    "slotType" : "UCDFS_Car_suspension_F",
    "slots": [
        ["type", "default", "description"],
        ["UCDFS_Car_hub_F","UCDFS_Car_hub_F_4", "Front Hubs",],     // parts can be loaded from other jbeam files
        //the coordinates of the nodeOffset determine where the common wheel is placed when it is loaded based on slot order
        ["UCDFS_Car_wheeldata_F_doublewishbone","UCDFS_Car_wheeldata_F_doublewishbone", "Front Spindles", {"coreSlot":true}],
        ["UCDFS_Car_coilover_F_doublewishbone","UCDFS_Car_coilover_F_doublewishbone", "Front Coilovers", {"nodeOffset":{"x":0, "y":0, "z":0.325}}],
        ["UCDFS_Car_swaybar_F_doublewishbone","UCDFS_Car_swaybar_F_doublewishbone", "Front Sway Bar", {"nodeOffset":{"x":0, "y":0, "z":0.325}}],
        ["UCDFS_Car_steering_doublewishbone","UCDFS_Car_steering_doublewishbone", "Steering", {"nodeOffset":{"x":0, "y":0, "z":0.325}}],
    ],
	
    "variables": [
        ["name", "type", "unit", "category", "default", "min", "max", "title", "description"],
		//camber
        ["$camber_F", "range", "m", "Wheel Alignment", 0.97, 0.75, 1.01, "Camber Adjust", "Adjusts the wheel camber angles", {"subCategory":"Front"}],
		],
	
    "flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
		//["FUL_Wishbone", ["upperarm_FL"], []],
		//["FUR_Wishbone", ["upperarm_FR"], []],
		//["FrontUR_Wishbone", ["upperarm_F"], []],
        
    ],
    "nodes": [
        ["id", "posX", "posY", "posZ"],
        {"collision":true},
        {"selfCollision":false},
        {"nodeMaterial":"|NM_METAL"},
        {"frictionCoef":0.5},
        {"nodeWeight":4.5},
        //hub mounting points for lower wishbone                   [Lower ball joint]
        {"group":["hub_F","lowerarm_F","shockbottom_F"]},
        ["fh1r", -0.6, -0.0125, -0.125],
        ["fh1l",  0.6, -0.0125, -0.125],

        //hub mounting points for upper wishbone                   [Upper ball joint]
        {"group":["hub_F","upperarm_FR"]},
        ["fh2r", -0.55, 0.0125, 0.075],
		{"group":["hub_F","upperarm_FL"]},
        ["fh2l",  0.55, 0.0125, 0.075],

        //tie rod end                                              [Outer tie rod ball joint]
        {"group":"tierod_F"},
        ["fh3r", -0.555, 0.16, -0.088],
        ["fh3l",  0.555, 0.16, -0.088],

        //brake caliper
        {"group":"brakearm_F"},
        ["fh5r", -0.61, -0.14, 0],
        ["fh5l",  0.61, -0.14, 0],

        //subframe
        {"nodeWeight":4.5},
        //body mounting points for lower wishbone
        {"group":["subframe_F","lowerarm_F"]},
        ["fx1r", -0.25, -0.2, -0.1],                              //[LCA front bush]
        ["fx1l",  0.25, -0.2, -0.1],                              //[LCA front bush]
        ["fx2r", -0.25,  0.2, -0.1, {"tag":"rideheight_FR"}],     //[LCA rear bush]
        ["fx2l",  0.25,  0.2, -0.1, {"tag":"rideheight_FL"}],     //[LCA rear bush]

        //body mounting points for upper wishbone
        {"group":["subframe_F","upperarm_FR"]},
        ["fx3r", -0.25, -0.15, 0.05],//0.1             //original 0.36                       //[UCA front bush]
        ["fx4r", -0.25,  0.15, 0.05],                                                   //[UCA rear bush]
		{"group":["subframe_F","upperarm_FL"]},
        ["fx3l",  0.25, -0.15, 0.05],                                                   //[UCA front bush]
        ["fx4l",  0.25,  0.15, 0.05],                                                   //[UCA rear bush]

        //body mounting points for spring and shock                                     [spring upper]
        {"group":["subframe_F","shocktop_F"]},
        ["fs1r", -0.25, 0.05, 0.355],
        ["fs1l",  0.25, 0.05, 0.355],
        {"group":""},
    ],
    "beams": [
        ["id1:", "id2:"],
        //double wishbone suspension
        {"beamPrecompression":1, "beamType":"|NORMAL"},
        {"beamSpring":3001000,"beamDamp":50},//{"beamSpring":7001000,"beamDamp":100},
        {"beamDeform":51000,"beamStrength":351000},
        //hub
        ["fh1r","fh2r"],
        ["fh1l","fh2l"],
        ["fh1r","fh3r"],
        ["fh1l","fh3l"],
        ["fh2r","fh3r"],
        ["fh2l","fh3l"],
        ["fh1r","fh5r"],
        ["fh1l","fh5l"],
        ["fh2r","fh5r"],
        ["fh2l","fh5l"],
        ["fh3r","fh5r"],
        ["fh3l","fh5l"],

        //hub to wheel axle nodes
        //breakGroup: when one beam breaks, all beams in the group are forced to break
        {"breakGroup":"wheel_FR"},
        //optional: tells the physics engine not to worry if it can't find the nodes (ex, user chose to remove the wheels that these beams should connect to)
        {"optional":true},
        ["fh1r","fw1r"],
        ["fh2r","fw1r", {"name":"axle_FR"}],
        ["fh3r","fw1r"],
        ["fh5r","fw1r"],
        ["fh1r","fw1rr"],
        ["fh2r","fw1rr"],
        ["fh3r","fw1rr"],
        ["fh5r","fw1rr"],
        {"breakGroup":"wheel_FL"},
        ["fh1l","fw1l", {"name":"axle_FL"}],
        ["fh2l","fw1l"],
        ["fh3l","fw1l"],
        ["fh5l","fw1l"],
        ["fh1l","fw1ll"],
        ["fh2l","fw1ll"],
        ["fh3l","fw1ll"],
        ["fh5l","fw1ll"],
        {"optional":false},
        {"breakGroup":""},

        //upper wishbone
        {"beamSpring":3001000,"beamDamp":50},//{"beamSpring":10001000,"beamDamp":2000},
        //slight alignment tweak for 0 camber at base ride height
        {"beamPrecompression":0.993},
        //{"highlight":{"radius":0.01, "col":"#0000FF7F"}},
        ["fh2r","fx3r", {"beamPrecompression":"$camber_F","dampCutoffHz":500,"beamPrecompressionTime":0.5}],
        ["fh2r","fx4r", {"beamPrecompression":"$camber_F","dampCutoffHz":500,"beamPrecompressionTime":0.5}],
        ["fh2l","fx3l", {"beamPrecompression":"$camber_F","dampCutoffHz":500,"beamPrecompressionTime":0.5}],
        ["fh2l","fx4l", {"beamPrecompression":"$camber_F","dampCutoffHz":500,"beamPrecompressionTime":0.5}],
        //{"highlight":{"radius":0.0, "col":"#00000000"}},
        {"beamPrecompression":1},

        //lower wishbone
        //{"highlight":{"radius":0.01, "col":"#FF00007F"}},
        ["fx2r","fh1r", {"dampCutoffHz":500,"beamPrecompressionTime":0.5}],
        ["fx1r","fh1r", {"dampCutoffHz":500,"beamPrecompressionTime":0.5}],
        ["fx2l","fh1l", {"dampCutoffHz":500,"beamPrecompressionTime":0.5}],
        ["fx1l","fh1l", {"dampCutoffHz":500,"beamPrecompressionTime":0.5}],
        //{"highlight":{"radius":0.0, "col":"#00000000"}},

        //subframe
        {"beamSpring":3001000,"beamDamp":250},//8001000
        ["fx3l", "fx1l"],
        ["fx4l", "fx2l"],
        ["fx3r", "fx1r"],
        ["fx4r", "fx2r"],
        ["fx1l", "fx2l"],
        ["fx3l", "fx4l"],
        ["fx1r", "fx2r"],
        ["fx3r", "fx4r"],
        ["fx1l", "fx1r"],
        ["fx3l", "fx3r"],
        ["fx2l", "fx2r"],
        ["fx4l", "fx4r"],
        ["fx1l", "fx4l"],
        ["fx3l", "fx2l"],
        ["fx1r", "fx4r"],
        ["fx3r", "fx2r"],
        ["fx1l", "fx3r"],
        ["fx3l", "fx1r"],
        ["fx4l", "fx2r"],
        ["fx2l", "fx4r"],
        ["fx1l", "fx2r"],
        ["fx2l", "fx1r"],
        ["fx3l", "fx4r"],
        ["fx4l", "fx3r"],

        //shock tower
        {"beamSpring":2001000,"beamDamp":250},//5001000
        ["fx3l", "fs1l"],
        ["fx4l", "fs1l"],
        ["fx3r", "fs1r"],
        ["fx4r", "fs1r"],
        ["fs1l", "fx1l"],
        ["fs1l", "fx2l"],
        ["fs1r", "fx1r"],
        ["fs1r", "fx2r"],
        ["fs1l", "fx3r"],
        ["fs1l", "fx4r"],
        ["fs1r", "fx3l"],
        ["fx4l", "fs1r"],
        ["fs1r", "fs1l"],

        //subframe to chassis
        {"beamSpring":3001000,"beamDamp":250},//6001000
        //{"highlight":{"radius":0.005, "col":"#ffff00ff"}}
        ["frb7l", "fx2l"],
        ["frb7r", "fx2r"],
        ["frm6l", "fx4l"],
        ["frm6r", "fx4r"],
        ["frb7l", "fx4l"],
        ["frb7r", "fx4r"],
        ["frm6l", "fx2l"],
        ["frm6r", "fx2r"],
        ["frb7r", "fx2l"],
        ["frb7l", "fx2r"],
        ["frm6r", "fx4l"],
        ["frm6l", "fx4r"],


        ["frb6r", "fx2r"],
        ["frb6l", "fx2l"],
        ["frm5r", "fx4r"],
        ["frm5l", "fx4l"],
        {"breakGroup":""},
        {"breakGroupType":0},
        {"optional":false},

        //front limiters prevent wheel from travelling through inside of car in crashes
        {"beamPrecompression":1, "beamType":"|BOUNDED", "beamLongBound":0.5, "beamShortBound":0.25},
        {"beamSpring":0,"beamDamp":0,"beamDeform":165000,"beamStrength":900000},
        {"beamLimitSpring":2001000,"beamLimitDamp":250},
        {"optional":true},
        {"breakGroupType":1},
        ["fw1ll","fx1r"],
        ["fw1ll","fx2r"],
        ["fw1ll","fx3r"],
        ["fw1ll","fx4r"],
        ["fw1rr","fx1l"],
        ["fw1rr","fx2l"],
        ["fw1rr","fx3l"],
        ["fw1rr","fx4l"],
        {"beamPrecompression":1},

        //wishbone inversion limiter
        {"beamPrecompression":1, "beamType":"|SUPPORT", "beamLongBound":2},
        {"beamSpring":1001000,"beamDamp":250,"beamDeform":165000,"beamStrength":900000},
        {"beamPrecompression":0.75},
        ["fx2l","fh2l"],
        ["fx1l","fh2l"],
        ["fx2r","fh2r"],
        ["fx1r","fh2r"],
        {"beamPrecompression":0.77},
        ["fx4r","fh1r"],
        ["fx3r","fh1r"],
        ["fx4l","fh1l"],
        ["fx3l","fh1l"],
        {"beamPrecompression":1},
        {"beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
    ],

    "pressureWheels": [
        ["name","hubGroup","group","node1:","node2:","nodeS","nodeArm:","wheelDir"],
        //cancel out brake properties before future wheel parts are loaded
        {"brakeTorque":0},
        {"parkingTorque":0},
        {"enableBrakeThermals":false},
        {"brakeDiameter":false},
        {"brakeMass":false},
        {"brakeType":false},
        {"rotorMaterial":false},
        {"brakeVentingCoef":false},
    ],
},

"UCDFS_Car_wheeldata_F_doublewishbone": {
    "information":{
        "authors":"BeamNG",
        "name":"Front Spindles",
        "value":0,
    },
    "slotType" : "UCDFS_Car_wheeldata_F_doublewishbone",
    "pressureWheels":[
        ["name","hubGroup","group","node1:","node2:","nodeS","nodeArm:","wheelDir"],
        //some wheel properties
        {"selfCollision":false},
        {"collision":true},
        {"hubcapBreakGroup":"hubcap_FR"},
        {"hubcapGroup":"hubcap_FR"},
        {"axleBeams":["axle_FR"]},
        //wheel is created from here, but using properties from previously loaded common jbeam parts
        ["FR", "wheel_FR", "tire_FR", "fw1rr", "fw1r", 9999, "fh5r", 1, {"torqueCoupling:":"fh3r","torqueArm:":"fh5r", "torqueArm2:":"fw1rr","steerAxisUp:":"fh2r","steerAxisDown:":"fh1r"}],
        {"hubcapBreakGroup":"hubcap_FL"},
        {"hubcapGroup":"hubcap_FL"},
        {"axleBeams":["axle_FL"]},
        ["FL", "wheel_FL", "tire_FL", "fw1ll", "fw1l", 9999, "fh5l", -1,{"torqueCoupling:":"fh3l","torqueArm:":"fh5l", "torqueArm2:":"fw1ll","steerAxisUp:":"fh2l","steerAxisDown:":"fh1l"}],
        //cancel out a bunch of properties before future wheel parts are loaded
        {"selfCollision":true},
        {"axleBeams":[]},{"disableMeshBreaking":false,"disableTriangleBreaking":false},
        {"hubcapBreakGroup":""},
        {"hubcapGroup":""},
        {"enableHubcaps":false},
        {"enableTireLbeams":false},
        {"enableTireSideReinfBeams":false},
        {"enableTireReinfBeams":false},
        {"enableTreadReinfBeams":false},
        {"enableTirePeripheryReinfBeams":false},
        {"loadSensitivitySlope":""},
        {"noLoadCoef":""},
        {"fullLoadCoef":""},
        {"frictionCoef":""},
        {"slidingFrictionCoef":""},
        {"softnessCoef":0.5},
        {"treadCoef":1.0},
    ],
},

"UCDFS_Car_swaybar_F_doublewishbone": {
    "information":{
        "authors":"BeamNG",
        "name":"Front Sway Bar",
        "value":250,
    },
    "slotType" : "UCDFS_Car_swaybar_F_doublewishbone",
    "flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
        //["swaybar_F", ["lowerarm_F", "swaybar_F"]],
    ],
	"variables": [
		["name", "type", "unit", "category", "default", "min", "max", "title", "description", {"stepDis":50, "subCategory":"Sway Bars"}],
		["$swayFront", "range", "Nm/rad", "Sway Bars", 1200, 600, 3000, "Front Sway Bar Stiffness", "Front anti-roll bar torsional rate"]
	],
    "torsionbars": [
        ["id1:", "id2:", "id3:", "id4:"],
        //torsional spring rate (Nm/rad) NOT end spring rate
        {"spring":"$swayFront", "damp":1, "deform":10000, "strength":50000},
        ["arbfr", "fx1r", "fx1l", "arbfl"],
    ],
    "nodes": [
        ["id", "posX", "posY", "posZ"],
        {"selfCollision":false},
        {"collision":true},
        {"nodeMaterial":"|NM_METAL"},
        {"frictionCoef":0.5},
        {"group":"swaybar_F"},
        {"nodeWeight":2.5},
        ["arbfr", -0.66, 0.4, -0.1],
        ["arbfl",  0.66, 0.4, -0.1],
        {"group":""},
    ],
    "beams": [
        ["id1:", "id2:"],
        {"beamPrecompression":1, "beamType":"|NORMAL"},
        {"beamSpring":1501000,"beamDamp":100},           //old spring 1501000
        {"beamDeform":52000,"beamStrength":712000},
        //end links
        ["arbfr","fh2r"],
        ["arbfl","fh2l"],
        //arm
        ["frb6r","arbfr"],
        ["frb6l","arbfl"],
        ["frb6l","arbfr"],
        ["frb6r","arbfl"],
        {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
    ],
},
"UCDFS_Car_coilover_F_doublewishbone": {
    "information":{
        "authors":"BeamNG",
        "name":"Front Coilovers",
        "value":200,
    },
    "slotType" : "UCDFS_Car_coilover_F_doublewishbone",
    "beams": [
        ["id1:", "id2:"],
        //springs
        {"beamPrecompression":1, "beamType":"|NORMAL"},
        {"beamSpring":27465,"beamDamp":0}, //50000
        {"beamDeform":31000,"beamStrength":251000},
        //precompressionRange specifies how much longer/shorter than spawn length the beam tries to achieve, in meters.
        //precompressionRange supersedes over beamPrecompression, make sure to only use this value inline with beams
        //{"highlight":{"radius":0.01, "col":"#FFFF007F"}},
        ["fh1r","fs1r", {"name":"spring_FR","precompressionRange":0.05}],//0.13
        ["fh1l","fs1l", {"name":"spring_FL","precompressionRange":0.05}],
        //{"highlight":{"radius":0.0, "col":"#00000000"}},

        //dampers
        {"beamPrecompression":1, "beamType":"|BOUNDED", "beamLongBound":1, "beamShortBound":1},
        {"beamSpring":0,"beamDamp":5708},           //C crit 7135
        {"beamLimitSpring":0,"beamLimitDamp":0},
        ["fh1r","fs1r", {"name":"damper_FR","beamDampRebound":7135,"beamDampVelocitySplit":0.1,"beamDampFast":3211,"beamDampReboundFast":4281,"dampCutoffHz":500}],
        ["fh1l","fs1l", {"name":"damper_FL","beamDampRebound":7135,"beamDampVelocitySplit":0.1,"beamDampFast":3211,"beamDampReboundFast":4281,"dampCutoffHz":500}],

        //suspension travel limits
        {"beamPrecompression":1, "beamType":"|BOUNDED"},
        {"beamSpring":0,"beamDamp":0},
        {"beamLimitSpring":501000,"beamLimitDamp":2000},
        //the Range values determine the start of the limit in meters from spawn length (not the precompressed length)
        //basically this is where the bumpstops are first contacted
        //the boundZone value determines the transition distance where spring and damp values approach limit values after reaching the Range
        //the spring and damp move towards limit values after passing the Range distance. At Range + boundZone, the spring and damp arrive at limit values.
        //basically this is how long/progressive the bumpstop is
        //these special values supersede over shortBound and longBound, make sure to only use this value inline with beams
        ["fh1r","fs1r", {"longBoundRange":0.09,"shortBoundRange":0.09,"boundZone":0.05,"dampCutoffHz":500}],
        ["fh1l","fs1l", {"longBoundRange":0.09,"shortBoundRange":0.09,"boundZone":0.05,"dampCutoffHz":500}],
        {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},
    ],
},


"UCDFS_Car_coilover_F_tunable": {
    "variables": [
        ["name", "type", "unit", "category", "default", "min", "max", "title", "description", {"stepDis":100, "subCategory":"Front"}],
        ["$frontSpringRate", "range", "N/m", "Suspension", 27000, 10000, 50000, "Front Spring Rate", "Front coilover spring stiffness"],
        ["$frontDampRebound", "range", "N/m/s", "Suspension", 5700, 500, 8000, "Front Rebound Damping", "Front damper rebound"]
    ],	
    "information":{
        "authors":"Harry",
        "name":"Front Coilovers - Tunable",
        "value":200
    },
    "slotType" : "UCDFS_Car_coilover_F_doublewishbone",   
    "beams": [
        ["id1:", "id2:"],
        {"beamPrecompression":1, "beamType":"|NORMAL"},
        {"beamSpring":"$frontSpringRate","beamDamp":0},         
        {"beamDeform":31000,"beamStrength":251000},
        //{"highlight":{"radius":0.01, "col":"#FFFF007F"}},
        ["fh1r","fs1r", {"name":"spring_FR","precompressionRange":0.05}],
        ["fh1l","fs1l", {"name":"spring_FL","precompressionRange":0.05}],
        //{"highlight":{"radius":0.0, "col":"#00000000"}},

        // dampers - softer rebound
        {"beamPrecompression":1, "beamType":"|BOUNDED", "beamLongBound":1, "beamShortBound":1},
        {"beamSpring":0,"beamDamp":"$frontDampRebound"}, //4200
        ["fh1r","fs1r", {"name":"damper_FR","beamDampRebound":7135,"beamDampVelocitySplit":0.1,"beamDampFast":3211,"beamDampReboundFast":4281,"dampCutoffHz":500}], //5235
        ["fh1l","fs1l", {"name":"damper_FL","beamDampRebound":7135,"beamDampVelocitySplit":0.1,"beamDampFast":3211,"beamDampReboundFast":4281,"dampCutoffHz":500}],

        // bumpstops same as stock
        {"beamPrecompression":1, "beamType":"|BOUNDED"},
		{"beamSpring":0,"beamDamp":0},
        {"beamLimitSpring":501000,"beamLimitDamp":2000},
        ["fh1r","fs1r", {"longBoundRange":0.09,"shortBoundRange":0.09,"boundZone":0.05,"dampCutoffHz":500}],
        ["fh1l","fs1l", {"longBoundRange":0.09,"shortBoundRange":0.09,"boundZone":0.05,"dampCutoffHz":500}]
		{"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1.0, "beamShortBound":1.0},

    ]
},

"UCDFS_Car_coilover_F_Stiff": {
    "information":{
        "authors":"Harry",
        "name":"Front Coilovers - Stiff",
        "value":200
    },
    "slotType" : "UCDFS_Car_coilover_F_doublewishbone",
    "beams": [
        ["id1:", "id2:"],
        {"beamPrecompression":1, "beamType":"|NORMAL"},
        {"beamSpring":40000,"beamDamp":0},           // harder spring
        {"beamDeform":31000,"beamStrength":251000},
        //{"highlight":{"radius":0.01, "col":"#FFFF007F"}},
        ["fh1r","fs1r", {"name":"spring_FR","precompressionRange":0.14}],
        ["fh1l","fs1l", {"name":"spring_FL","precompressionRange":0.14}],
        //{"highlight":{"radius":0.0, "col":"#00000000"}},

        // dampers - harder rebound
        {"beamPrecompression":1, "beamType":"|BOUNDED", "beamLongBound":1, "beamShortBound":1},
        {"beamSpring":0,"beamDamp":4200},
        ["fh1r","fs1r", {"name":"damper_FR","beamDampRebound":9500,"beamDampFast":2400,"dampCutoffHz":500}],
        ["fh1l","fs1l", {"name":"damper_FL","beamDampRebound":9500,"beamDampFast":2400,"dampCutoffHz":500}],

        // bumpstops same as stock
        {"beamPrecompression":1, "beamType":"|BOUNDED"},
        {"beamLimitSpring":501000,"beamLimitDamp":2000},
        ["fh1r","fs1r", {"longBoundRange":0.09,"shortBoundRange":0.09,"boundZone":0.05,"dampCutoffHz":500}],
        ["fh1l","fs1l", {"longBoundRange":0.09,"shortBoundRange":0.09,"boundZone":0.05,"dampCutoffHz":500}]
    ]
},


"UCDFS_Car_steering_doublewishbone": {
    "information":{
        "authors":"BeamNG",
        "name":"Rack and Pinion Steering",
        "value":110,
    },
    "slotType" : "UCDFS_Car_steering_doublewishbone",
    "flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
    ],
    //steering rack rail
    //rails form a line between 2 nodes that slidenodes will slide on. Used for any kind of telescoping motion such as steering racks, hydraulic rams, strut shafts.
    "rails": {
        "steeringrack":{"links:":["st2r", "st2l"], "broken:":[], "looped":false, "capped":true},
    },
    "slidenodes": [
        ["id:", "railName", "attached", "fixToRail", "tolerance", "spring", "strength", "capStrength"],
        ["st1r", "steeringrack", true, true, 0.0, 10001000, "FLT_MAX", "FLT_MAX"],
        ["st1l", "steeringrack", true, true, 0.0, 10001000, "FLT_MAX", "FLT_MAX"],
    ],
    "nodes": [
        ["id", "posX", "posY", "posZ"],
        {"selfCollision":false},
        {"collision":true},
        {"nodeMaterial":"|NM_METAL"},
        {"frictionCoef":0.5},
        {"group":"tierod_F"},
        {"nodeWeight":4.0},
        //steering rack ends
        ["st2r", -0.22, 0.57, -0.08],
        ["st2l",  0.22, 0.57, -0.08],
        //body mounting points for steering rack
        {"nodeWeight":8.0},
        ["st1r", -0.10, 0.57, -0.08],
        ["st1l",  0.10, 0.57, -0.08],
        {"group":""},
    ],
    "beams": [
        ["id1:","id2:"],
        {"beamPrecompression":1.0, "beamType":"|NORMAL", "beamLongBound":1, "beamShortBound":1},
        {"beamSpring":5001000,"beamDamp":100},
        {"beamDeform":39500,"beamStrength":63750},
        //steering rack mounting to body
        ["st1l", "st1r"],
        ["fx1l", "st1l"],
        ["fx2l", "st1l"],
        ["fx1r", "st1r"],
        ["fx2r", "st1r"],
        ["st1l", "fx2r"],
        ["st1r", "fx2l"],
        ["fx1l", "st1r"],
        ["fx1r", "st1l"],
        ["fx4l", "st1l"],
        ["fx4r", "st1r"],
        ["fx4r", "st1l"],
        ["fx4l", "st1r"],

        //center link
        {"beamSpring":12001000,"beamDamp":250},
        ["st2r","st2l"],

        //tie rod ends
        {"beamSpring":12001000,"beamDamp":250},
        //{"highlight":{"radius":0.01, "col":"#0080007F"}},
        ["fh3r","st2r", {"beamPrecompression":0.9995}],
        ["fh3l","st2l", {"beamPrecompression":0.9995}],
        //{"highlight":{"radius":0.0, "col":"#00000000"}},

        //steering limit
        {"beamPrecompression":1, "beamType":"|SUPPORT", "beamLongBound":4},
        {"beamSpring":5001000,"beamDamp":250,"beamDeform":120000,"beamStrength":160000},
        {"beamPrecompression":0.73},
        ["fh3r","fx1r"],
        ["fh3l","fx1l"],
        {"beamPrecompression":0.78},
        ["fh5r","fx2r"],
        ["fh5l","fx2l"],
        {"beamPrecompression":1},

        //steering damper
        //doesnt interfere at normal steering speeds but dampens violent shakes
        {"beamPrecompression":1.0, "beamType":"|BOUNDED", "beamLongBound":1.0, "beamShortBound":1.0},
        {"beamDeform":10000,"beamStrength":10000},
        {"beamLimitSpring":0,"beamLimitDamp":0},
        {"beamSpring":0,"beamDamp":0},
        ["fh3r","fx1r", {"beamDampVelocitySplit":0.1,"beamDampFast":2000,"beamDampReboundFast":2000,"beamDamp":0,"beamDampRebound":0,"dampCutoffHz":1000}],
        ["fh3l","fx1l", {"beamDampVelocitySplit":0.1,"beamDampFast":2000,"beamDampReboundFast":2000,"beamDamp":0,"beamDampRebound":0,"dampCutoffHz":1000}],
        ["fh5r","fx2r", {"beamDampVelocitySplit":0.1,"beamDampFast":2000,"beamDampReboundFast":2000,"beamDamp":0,"beamDampRebound":0,"dampCutoffHz":1000}],
        ["fh5l","fx2l", {"beamDampVelocitySplit":0.1,"beamDampFast":2000,"beamDampReboundFast":2000,"beamDamp":0,"beamDampRebound":0,"dampCutoffHz":1000}],
        {"beamPrecompression":1.0, "beamType":"|NORMAL", "beamLongBound":1, "beamShortBound":1},
    ],
    "hydros": [
        ["id1:","id2:"],
        {"beamPrecompression":1.0, "beamType":"| BOUNDED", "beamLongBound":1, "beamShortBound":1},
        {"beamSpring":3001000,"beamDamp":0,"beamDeform":"FLT_MAX","beamStrength":176500},
        //hydros are beams which can change their target length over time, in this case connected to the steering input
        //factor is the maximum change in length (beam length ratio) used to set steering rack travel
        //steeringWheelLock is a value which affects steering wheel prop and steering speed when using assisted steering (kbd/pad)
        ["st2l","st1r", {"factor":0.26, "steeringWheelLock":450, "inRate":1.25,"outRate":1.25}],
        ["st2r","st1l", {"factor":-0.26,"steeringWheelLock":450, "inRate":1.25,"outRate":1.25}],
        {"beamPrecompression":1.0, "beamType":"|NORMAL", "beamLongBound":1, "beamShortBound":1},
    ],
    "input": {
        //modifier for force feedback to account for differences in vehicles
        "FFBcoef":5,
    },
},
}