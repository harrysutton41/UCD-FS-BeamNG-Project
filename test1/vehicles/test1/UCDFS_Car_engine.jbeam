        ["differential", "differential_R", "differential_C", 1, {"diffType":"locked", "gearRatio":4,"friction":4, "lockTorque":50000, "uiName":"Rear Differential"}],
        ["shaft", "wheelaxleRL", "differential_R", 1, {"connectedWheel":"RL", "breakTriggerBeam":"axle_RL", "uiName":"Rear Left Axle", "friction":1}],
        ["shaft", "wheelaxleRR", "differential_R", 2, {"connectedWheel":"RR", "breakTriggerBeam":"axle_RR", "uiName":"Rear Right Axle", "friction":1}],

        ["differential", "differential_F", "differential_C", 2, {"diffType":"locked","gearRatio":4,"friction":4, "lockTorque":50000, "uiName":"Front Differential"}],
        ["shaft", "wheelaxleFL", "differential_F", 1, {"connectedWheel":"FL", "breakTriggerBeam":"axle_FL", "uiName":"Front Left Axle", "friction":1.2}],
        ["shaft", "wheelaxleFR", "differential_F", 2, {"connectedWheel":"FR", "breakTriggerBeam":"axle_FR", "uiName":"Front Right Axle", "friction":1.2}],
    ],
},

