"UCDFS_Car_transmission_5M": {
    "information":{
        "authors":"BeamNG",
        "name":"5-Speed Manual Transmission",
        "value":250,
    },

    "slotType" : "UCDFS_Car_transmission",

    "slots": [
        ["type", "default", "description"],
    ],
    "powertrain": [
        ["type", "name", "inputName", "inputIndex"],
        ["frictionClutch", "clutch", "mainEngine", 1],
        ["manualGearbox", "gearbox", "clutch", 1],
    ],
    "gearbox": {
        "uiName":"Gearbox",
        "gearRatios":[-3.15, 0, 3.25, 1.895, 1.26, 0.94, 0.77],
        "friction": 5,
    },
    ,
    "vehicleController": {},
},

"UCDFS_Car_differential_4wd_electric": {
    "information":{
        "authors":"BeamNG",
        "name":"4WD Differential     Electric",
        "value":200,
    },

    "slotType" : "UCDFS_Car_differential_electric_R",

    "variables": [
        ["name", "type", "unit", "category", "default", "min", "max", "title", "description"],
        //["$finaldrive_R", "range", ":1", "Differentials", 4.0, 1.0, 10.0, "Final Drive Ratio", "Torque multiplication ratio"],   hardcoded ratio
    ],
    "powertrain" : [
        ["type", "name", "inputName", "inputIndex"],
        ["differential", "differential_C", "mainEngine", 1, {"diffType":"locked", "gearRatio":1.0,"friction":4, "lockTorque":5000, "uiName":"Center Differential"}],

        ["differential", "differential_R", "differential_C", 1, {"diffType":"open", "gearRatio":7.5,"friction":4, "lockTorque":50000, "uiName":"Rear Differential"}],
        ["shaft", "wheelaxleRL", "differential_R", 1, {"connectedWheel":"RL", "breakTriggerBeam":"axle_RL", "uiName":"Rear Left Axle", "friction":1}],
        ["shaft", "wheelaxleRR", "differential_R", 2, {"connectedWheel":"RR", "breakTriggerBeam":"axle_RR", "uiName":"Rear Right Axle", "friction":1}],

        ["differential", "differential_F", "differential_C", 2, {"diffType":"open","gearRatio":7.5,"friction":4, "lockTorque":50000, "uiName":"Front Differential"}],
        ["shaft", "wheelaxleFL", "differential_F", 1, {"connectedWheel":"FL", "breakTriggerBeam":"axle_FL", "uiName":"Front Left Axle", "friction":1.2}],
        ["shaft", "wheelaxleFR", "differential_F", 2, {"connectedWheel":"FR", "breakTriggerBeam":"axle_FR", "uiName":"Front Right Axle", "friction":1.2}],
    ],
},

