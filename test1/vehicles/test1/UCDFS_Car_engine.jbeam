{
"UCDFS_Car_engine": {
    "information":{
        "authors":"BeamNG",
        "name":"1.5L DOHC I4 Engine",
        "value":850,
    },

    "slotType" : "UCDFS_Car_engine",

    "slots": [
        ["type", "default", "description"],
        ["UCDFS_Car_transmission","UCDFS_Car_transmission_5M", "Transmission"],
        ["UCDFS_Car_differential",    "UCDFS_Car_differential_R",       "Differential"],
    ],
    "flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
    ],
    "powertrain": [
        ["type", "name", "inputName", "inputIndex"],
        ["combustionEngine", "mainEngine", "dummy", 0],
    ],
    "mainEngine": {
        "torque":[
            ["rpm", "torque"],
            [0, 0],
            [500, 50],
            [1000, 84],
            [1500, 108],
            [2000, 122],
            [3000, 156],
            [4000, 169],
            [5000, 167],
            [6000, 163],
            [7000, 143],
            [7500, 129],
            [8000, 102],
            [9000, 79],
        ],

        "idleRPM":1000,
        "maxRPM":6900,
        "inertia":0.10,
        "friction":11,
        "dynamicFriction":0.022,
        "burnEfficiency":0.31,
        //"torqueReactionNodes:":["b2r","b2l","b12r"],
        "particulates":0.03,

        //cooling and oil system
        "thermalsEnabled":false,
        "engineBlockMaterial":"aluminum",
        "oilVolume":3,

        //engine durability
        "cylinderWallTemperatureDamageThreshold":130,
        "headGasketDamageThreshold":1500000,
        "pistonRingDamageThreshold":1500000,
        "connectingRodDamageThreshold":2000000,

        //node beam interface
        //this simply chooses an engineGroup name to use. The engineGroup name must be present in the nodes themselves
        //choose a group near the engine's intake for appropriate engine drowning
        "waterDamage": {"[engineGroup]:":["engine_intake"]},
        //choose a group for radiator steam to be emitted from
        "radiator": {"[engineGroup]:":["radiator"]},
        //choose a group that represents the engine block mass
        "engineBlock": {"[engineGroup]:":["engine_block"]},
        //choose beam name. When any beam containing that name breaks it will disable the device. The beam name must be present in the beams themselves
        "breakTriggerBeam":"engine",
        //this is just a nicer string to pass to the UI
        "uiName":"Engine",
    },
    "vehicleController": {
        "clutchLaunchStartRPM":2300,
        "clutchLaunchTargetRPM":3000,

        "highShiftDownRPM":[0,0,0,2700,3350,3600,3800,3800],
        "highShiftUpRPM":6600,
        "lowShiftDownRPM":[0,0,0,2700,3350,3600,3800,3800],
        "lowShiftUpRPM":5000,
    },
},

"UCDFS_Car_electricMotor": {
		"variables": [
        ["name", "type", "unit", "category", "default", "min", "max", "title", "description", {"stepDis":5, "subCategory":""}],
        ["$trailingMotorTorque", "range", "Nm", "Motor", 120, 80, 180, "Trailing Motor Torque", "Make 10 less than peak"],
		["$peakMotorTorque", "range", "Nm", "Motor", 140, 100, 200, "Peak Motor Torque", ""]
    ],	
    "information":{
        "authors":"BeamNG",
        "name":"Rear Electric Motor",
        "value":850,
    },

    "slotType" : "UCDFS_Car_engine",
    "flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
    ],

    "slots": [
        ["type", "default", "description"],
        ["UCDFS_Car_differential_electric_R",    "UCDFS_Car_differential_R_electric",       "Electric Differential"],
    ],

    "powertrain": [
        ["type", "name", "inputName", "inputIndex"],
        ["electricMotor", "mainEngine", "dummy", 0],
        //["frictionClutch", "clutch", "mainEngine", 1],
    ],
    "mainEngine": {
        "torque":[
            ["rpm", "torque"],
            [0,    	"$peakMotorTorque"],//	  140],   //170],    //220.00 ],      
            [500,  	"$peakMotorTorque"],//	  140],   //180],    //256.67],       
             [1000,	"$peakMotorTorque"],//	  140],   //190],    //300.00 ],      
             [1500,	"$peakMotorTorque"],//	  140],   //190],    //333.33 ],      
             [2000,	"$peakMotorTorque"],//	  140],   //190],    //333.33 ],      
             [3000,	"$peakMotorTorque"],//	  140],   //190],    //333.33 ],      
             [4000,	"$peakMotorTorque"],//	  140],   //190],    //333.33 ],      
             [5000,	"$trailingMotorTorque"],//	130],   //190],    //333.33 ],      
             [6000,	"$trailingMotorTorque"],//	115],   //190],    //333.33 ],      
             //[7000,170],   //185],    //333.33 ],      
           //  [8000,    190.00],
           // [9000,    166.67],
           // [10000,     150.00],
           // [11000,    133.33],
           // [12000,   106.67],
           // [13000,  90.00],
           // [14000, 73.33],
           // [15000,  60.00],
           // [16000, 53.33],
        ],         
        "maxRPM":6000, //16000
        "maxRegenPower":150,
        "maxRegenTorque":100,
        "inertia":0.05,
        "friction":2,
        "dynamicFriction":0.0003,
        "electricalEfficiency":0.96,
        //"torqueReactionNodes:":["b2r","b2l","b12r"]

        //node beam interface
        //this simply chooses an engineGroup name to use. The engineGroup name must be present in the nodes themselves
        //choose a group near the engine's intake for appropriate engine drowning
        "waterDamage": {"[engineGroup]:":["engine_intake"]},
        //choose beam name. When any beam containing that name breaks it will disable the device. The beam name must be present in the beams themselves
        "breakTriggerBeam":"engine",
        //this is just a nicer string to pass to the UI
        "uiName":"Engine",
    "soundConfig": "soundConfig",
    },
    "soundConfig": {

    },
    "vehicleController": {
        "shiftLogicName":"electricMotor",
        "motorNames": ["mainEngine"],
    },
},

